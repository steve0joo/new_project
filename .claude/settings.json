{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-checks.sh\"",
            "timeout": 120,
            "statusMessage": "pre-commit 검사 (lint + 문법)…"
          }
        ]
      }
    ]
  }
}
